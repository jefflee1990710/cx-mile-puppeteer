# Copy to .env.local (gitignored) — never commit secrets.

# --- 2) Residential proxy (session-pinned for the whole scan process) ---
# Example: http://user:pass@gate.example.com:8000
# Prefer sticky/residential sessions; do NOT rotate per click.
CX_PROXY_SERVER=
CX_PROXY_USER=
CX_PROXY_PASS=

# --- 5) TLS / remote Chrome (Browserless, BrowserAct, etc.) ---
# When set, connects via CDP instead of launching local Chrome.
# Provider should sync JA/TLS fingerprint with the browser version.
# Example: wss://chrome.browserless.io?token=YOUR_TOKEN
CX_BROWSER_WS=
# BROWSERLESS_WS=   # alias also accepted

# --- Attach to YOUR real Chrome (closest to the extension) ---
# Prefer this over launching Puppeteer Chrome — skips stealth/fingerprint patches.
# macOS/Linux:  ./scripts/launch-chrome-debug.sh
# Windows:      .\scripts\launch-chrome-debug.ps1
# Then set:
CX_CDP_URL=
# Example: http://127.0.0.1:9222
# If Access Denied persists, wipe the debug profile and relaunch:
#   rm -rf ~/.cx-mile-puppeteer/chrome-debug-profile
#   Remove-Item -Recurse -Force $HOME\.cx-mile-puppeteer\chrome-debug-profile

# Optional: persistent profile for Puppeteer-launched Chrome (non-CDP path)
# CX_CHROME_PROFILE=
# Force bundled Chromium instead of system Google Chrome (worse vs Akamai)
# CX_USE_BUNDLED_CHROMIUM=1
# Force stealth + spoofed fingerprint even on system Chrome (usually worse vs Akamai)
# CX_FORCE_FINGERPRINT=1
